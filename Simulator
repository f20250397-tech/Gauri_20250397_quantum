if __name__ == "__main__":
    # Approximate starting memory check
    approx_base_mem = sys.getsizeof(np.zeros(1))

    print("==================================================")
    print("DEMO 1: Generating a 2-Qubit Bell State (|00> + |11>) / sqrt(2)")
    print("==================================================")
    
    # Track overall circuit processing window
    start_workflow = time.perf_counter()
    
    sim_bell = QuantumSimulator(num_qubits=2)
    print("Initial State:")
    sim_bell.display_state()
    
    # 1. Apply Hadamard to Qubit 0 -> Superposition
    print("\nApplying H gate to Qubit 0...")
    sim_bell.apply_single_gate('H', target_qubit=0)
    sim_bell.display_state()
    
    # 2. Entangle Qubit 0 and Qubit 1 via CNOT
    print("\nApplying CNOT (Control: 0, Target: 1)...")
    sim_bell.apply_cnot(control_qubit=0, target_qubit=1)
    sim_bell.display_state()
    
    sim_bell.total_execution_time = time.perf_counter() - start_workflow
    sim_bell.print_kpis(approx_base_mem)


    print("\n\n==================================================")
    print("DEMO 2: Quantum Coin Toss / Random Number Generator (3 Qubits)")
    print("==================================================")
    
    start_workflow = time.perf_counter()
    sim_rng = QuantumSimulator(num_qubits=3)
    
    # Apply Hadamard to all 3 qubits to construct uniform superposition across 8 possible states
    for q in range(3):
        sim_rng.apply_single_gate('H', target_qubit=q)
        
    sim_rng.display_state()
    
    sim_rng.total_execution_time = time.perf_counter() - start_workflow
    sim_rng.print_kpis(approx_base_mem)
