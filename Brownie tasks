import sys
import numpy as np
import matplotlib.pyplot as plt

# CHALLENGE A : VISUALIZATION

def plot_probabilities(simulator, title="Quantum State Probabilities"):
    probs = simulator.get_probabilities()

    states = [
        format(i, f'0{simulator.num_qubits}b')
        for i in range(simulator.state_dim)
    ]

    plt.figure(figsize=(8, 4))
    plt.bar(states, probs, color="crimson")

    plt.xlabel("States")
    plt.ylabel("Probability")
    plt.title(title)
    plt.grid(axis="y", linestyle="--", alpha=0.5)

    plt.show()


# CHALLENGE B : FIXED POINT EMULATION

def emulate_fixed_point(val, fractional_bits=8):

    scale = 1 << fractional_bits

    real_part = round(val.real * scale) / scale
    imag_part = round(val.imag * scale) / scale

    return complex(real_part, imag_part)


def run_fixed_point_analysis(fractional_bits):

    print(f"\nPrecision = {fractional_bits} bits")

    ideal = 1 / np.sqrt(2)

    quantized = emulate_fixed_point(
        complex(ideal, 0),
        fractional_bits
    )

    ideal_prob = ideal ** 2
    quant_prob = abs(quantized) ** 2

    error = abs(ideal_prob - quant_prob)

    print(f"Ideal Amplitude     : {ideal:.8f}")
    print(f"Quantized Amplitude : {quantized.real:.8f}")
    print(f"Ideal Probability   : {ideal_prob:.8f}")
    print(f"Quantized Prob      : {quant_prob:.8f}")
    print(f"Absolute Error      : {error:.8f}")

    # Probabilities

    def get_probabilities(self):

        if self.use_sparse:

            probs = np.zeros(self.state_dim)

            for idx, amp in self.sparse_state.items():
                probs[idx] = abs(amp) ** 2

            return probs

        return np.abs(self.state_vector) ** 2

    # Memory usage

    def get_memory_usage(self):

        if self.use_sparse:

            return (
                sys.getsizeof(self.sparse_state)
                + sum(
                    sys.getsizeof(k)
                    + sys.getsizeof(v)
                    for k, v in self.sparse_state.items()
                )
            )

        return self.state_vector.nbytes


